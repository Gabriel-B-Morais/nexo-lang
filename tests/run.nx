print("=== Nexo rodando ===")

nome = "Gabriel"
idade = 10
print("Nome:", nome)
print("Idade:", idade)

soma = 10 + 5 * 2
print("10 + 5 * 2 =", soma)

resultado = (1 + 2) * 3
print("(1 + 2) * 3 =", resultado)

if idade > 18
  print(nome + " e maior de idade")
else
  print(nome + " e menor de idade")
end

print("--- Contagem regressiva ---")
contador = 3
while contador > 0
  print(contador)
  contador--
end
print("Fim!")

print("--- Foreach ---")
numeros = [10, 20, 30]
foreach numeros as n
  print("Numero:", n)
end

func saudacao(pessoa: string) -> string
  return "Ola, " + pessoa + "!"
end

print(saudacao("Mundo"))
print(saudacao(nome))

func fatorial(n: int) -> int
  if n <= 1
    return 1
  end
  return n * fatorial(n - 1)
end

print("Fatorial de 5:", fatorial(5))

func fib(n: int) -> int
  if n < 2
    return n
  end
  return fib(n - 1) + fib(n - 2)
end

print("Fibonacci de 10:", fib(10))