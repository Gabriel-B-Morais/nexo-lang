print("=== OOP no Nexo ===")

class Animal
  public name: string
  public sound: string

  construct(name: string, sound: string)
    this.name = name
    this.sound = sound
  end

  public func speak() -> string
    return this.name + " faz " + this.sound
  end
end

a = new Animal("Cachorro", "Au Au")
print(a.speak())

b = new Animal("Gato", "Miau")
print(b.speak())

print("--- Heranca ---")

class Pessoa
  public name: string

  construct(name: string)
    this.name = name
  end

  public func greet() -> string
    return "Ola, eu sou " + this.name
  end
end

class Funcionario extends Pessoa
  public salary: int

  public func describe() -> string
    return this.name + " ganha " + this.salary
  end
end

f = new Funcionario("Gabriel")
f.name = "Gabriel Morais"
f.salary = 5000
print(f.greet())
print(f.describe())

print("--- Contador com estado ---")

class Contador
  public valor: int = 0

  public func incrementar()
    this.valor++
  end

  public func get() -> int
    return this.valor
  end
end

c = new Contador()
c.incrementar()
c.incrementar()
c.incrementar()
print("Valor:", c.get())